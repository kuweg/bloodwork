# ---- Postgres ----
POSTGRES_DB=bloodwork
POSTGRES_USER=bloodwork
POSTGRES_PASSWORD=change-me-postgres-password

# ---- Backend ----
BW_DATABASE_URL=postgresql+asyncpg://bloodwork:change-me-postgres-password@db:5432/bloodwork
BW_UPLOAD_DIR=./uploads
BW_BLOODWORK_DATA_DIR=/blood_work_data
BW_CORS_ORIGINS=["https://your-domain.example"]

# LLM provider: openai | anthropic | deepseek
BW_LLM_PROVIDER=openai
BW_LLM_API_KEY=replace-me
BW_LLM_MODEL=
BW_LLM_TIMEOUT_SECONDS=60.0

# Sessions / auth
BW_SESSION_SECRET=replace-with-long-random-secret
BW_SESSION_COOKIE_NAME=bw_session
BW_SESSION_TTL_HOURS=336
BW_SESSION_SECURE_COOKIE=true

# Bootstrap admin
BW_BOOTSTRAP_ADMIN_LOGIN=kuweg_admin
BW_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
